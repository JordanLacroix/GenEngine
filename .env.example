GENENGINE_JWT_SECRET=replace-with-at-least-32-random-characters
GENENGINE_INTERNAL_KEY=replace-with-a-random-internal-service-key
GENENGINE_BOOTSTRAP_KEY=replace-with-at-least-24-random-characters
AUTHORING_DB_PASSWORD=replace-authoring-password
PLAY_DB_PASSWORD=replace-play-password
IDENTITY_DB_PASSWORD=replace-identity-password
CONFIGURATION_DB_PASSWORD=replace-configuration-password
PLAYER_EXPERIENCE_DB_PASSWORD=replace-player-experience-password
AUTHENTICATION_MODE=Cumulative
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_DEPLOYMENT=
# Resolves the `env:GENENGINE_AI_AZURE_FOUNDRY_KEY` reference stored in the configuration
# document. Leave empty to keep the Azure provider unconfigured and stay offline.
GENENGINE_AI_AZURE_FOUNDRY_KEY=
