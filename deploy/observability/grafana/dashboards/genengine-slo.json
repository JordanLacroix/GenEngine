{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "description": "SLI/SLO provisoires de développement. Seuils non contractuels — voir specs/process/slo.md.",
  "panels": [
    {
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "options": {
        "mode": "markdown",
        "content": "**Objectifs provisoires de développement — non contractuels.** Disponibilité cible 99 %, latence p95 < 500 ms. Le trafic `/health/*` est exclu. Définitions et révision : `specs/process/slo.md`."
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "Disponibilité (SLI) — objectif 99 %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.9,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.99 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "service:http_availability:ratio5m", "legendFormat": "{{service_name}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "Taux d'erreurs 5xx (SLI) — seuils de burn",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.06 },
              { "color": "red", "value": 0.144 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "dashed" }
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "service:http_error_ratio:rate5m", "legendFormat": "{{service_name}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "Latence p95 (SLI) — objectif < 500 ms",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "service:http_request_duration_seconds:p95_5m", "legendFormat": "{{service_name}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "Budget d'erreur restant sur 30 j (objectif 99 %)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "clamp_min(1 - ( (sum by (service_name) (increase(http_server_request_duration_seconds_count{service_name=~\"genengine-.*\", http_route!~\"/health/.*\", http_response_status_code=~\"5..\"}[30d])) / clamp_min(sum by (service_name) (increase(http_server_request_duration_seconds_count{service_name=~\"genengine-.*\", http_route!~\"/health/.*\"}[30d])), 1)) / 0.01 ), 0)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 41,
  "tags": ["genengine", "slo"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "GenEngine — SLO et budget d'erreur",
  "uid": "genengine-slo",
  "version": 1
}
