      "targets": [
        { "expr": "sum by (service_name) (dotnet_gc_last_collection_heap_size_bytes{service_name=~\"genengine-.*\"})", "legendFormat": "{{service_name}}", "refId": "A" }
      ],
      "title": "Taille du heap après le dernier GC",
