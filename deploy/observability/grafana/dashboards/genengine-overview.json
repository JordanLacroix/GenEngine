      "title": "Débit HTTP",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{service_name=~\"genengine-.*\"}[5m])))", "legendFormat": "{{service_name}}", "refId": "A" }
      ],
      "title": "Latence HTTP p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{service_name=~\"genengine-.*\", http_response_status_code=~\"5..\"}[5m]))", "legendFormat": "{{service_name}}", "refId": "A" }
      ],
      "title": "Erreurs HTTP 5xx",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
